#include <dt-bindings/zmk/matrix_transform.h>
#include <zephyr/dt-bindings/gpio/gpio.h>

/*
 * Pin mapping assumption
 * -----------------------
 * The ergogen source uses net names P0..P10 for column_net / row_net.
 * These line up 1:1 with the Xiao BLE's 11 broken-out GPIO pins, D0..D10,
 * which is what &xiao_d N refers to in ZMK. If your actual schematic wired
 * these nets to different physical MCU pins, update the row/col-gpios below
 * to match your board, not the net label.
 *
 * Column nets (main matrix):
 *   P0 outer   P1 pinky   P2 ring   P3 middle   P4 index   P5 inner
 * Column nets (thumb cluster):
 *   P10 thumb-left   P9 thumb-right
 * Row nets:
 *   P6 top   P8 home   P7 bottom
 *
 * Diode direction: ergogen wires switch column_net -> switch -> diode -> row_net,
 * i.e. the column is driven and the row is sensed => col2row.
 */

/ {
	chosen {
		zmk,kscan = &kscan0;
		zmk,physical-layout = &physical_layout0;
	};

	kscan0: kscan0 {
		compatible = "zmk,kscan-gpio-matrix";
		diode-direction = "col2row";
		wakeup-source;

		row-gpios
                = <&xiao_d 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
                , <&xiao_d 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
                , <&xiao_d 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
			;

		col-gpios
			= <&xiao_d 0 GPIO_ACTIVE_HIGH>   // P0  - col: outer
			, <&xiao_d 1 GPIO_ACTIVE_HIGH>   // P1  - col: pinky
			, <&xiao_d 2 GPIO_ACTIVE_HIGH>   // P2  - col: ring
			, <&xiao_d 3 GPIO_ACTIVE_HIGH>   // P3  - col: middle
			, <&xiao_d 4 GPIO_ACTIVE_HIGH>   // P4  - col: index
			, <&xiao_d 5 GPIO_ACTIVE_HIGH>   // P5  - col: inner
			, <&xiao_d 10 GPIO_ACTIVE_HIGH>  // P10 - col: thumb-left
			, <&xiao_d 9 GPIO_ACTIVE_HIGH>   // P9  - col: thumb-right
			;
	};

	/*
	 * Combined transform for both halves.
	 * Local column indices 0-7 per half (see kscan0 above):
	 *   0 outer, 1 pinky, 2 ring, 3 middle, 4 index, 5 inner, 6 thumb-left, 7 thumb-right
	 * The right half reports its own kscan with the same 0-7 local indices;
	 * chamomile_right.overlay applies col-offset = <8> to shift those events
	 * into columns 8-15 here, so the right half mirrors the left in this map:
	 *   8 outer, 9 pinky, 10 ring, 11 middle, 12 index, 13 inner, 14 thumb-left, 15 thumb-right
	 *
	 * Rows: 0 = top (P6), 1 = home (P8), 2 = bottom (P7)
	 */
	default_transform: keymap_transform_0 {
		compatible = "zmk,matrix-transform";
		columns = <16>;
		rows = <3>;

		map = <
//          left: outer  pinky   ring    middle  index   inner         right: inner    index    middle   ring     pinky    outer
			RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)     RC(0,13) RC(0,12) RC(0,11) RC(0,10) RC(0,9) RC(0,8)
			RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)     RC(1,13) RC(1,12) RC(1,11) RC(1,10) RC(1,9) RC(1,8)
			RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)     RC(2,13) RC(2,12) RC(2,11) RC(2,10) RC(2,9) RC(2,8)
			                                RC(1,6) RC(1,7)                              RC(1,15) RC(1,14)
			                                RC(2,6) RC(2,7)                              RC(2,15) RC(2,14)
		>;
	};

	physical_layout0: physical_layout_0 {
		compatible = "zmk,physical-layout";
		display-name = "Default Layout";
		transform = <&default_transform>;
	};
};

&uart0 {
    status = "disabled";
};
